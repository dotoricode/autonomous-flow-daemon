{
  "name": "@dotoricode/afd",
  "version": "2.0.0-dev.1",
  "description": "Zero-config immunity for AI coding workflows. Self-heals broken configs in < 270ms.",
  "type": "module",
  "bin": {
    "afd": "bin/afd.cjs"
  },
  "main": "./src/cli.ts",
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "bin/afd.cjs",
    "src/**/*.ts",
    "mcp-config.json",
    "README.md",
    "README-ko.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "self-healing",
    "mcp",
    "bun",
    "ai-workflow",
    "daemon",
    "autonomous",
    "dev-tools"
  ],
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "score": "bun src/cli.ts score",
    "start": "bun src/cli.ts start",
    "test": "bun test"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "web-tree-sitter": "^0.26.8"
  },
  "license": "MIT",
  "optionalDependencies": {
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}
