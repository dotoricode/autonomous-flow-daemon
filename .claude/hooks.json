{
  "hooks": {
    "PreToolUse": [
      {
        "id": "afd-auto-heal",
        "matcher": "Write|Edit|MultiEdit",
        "command": "afd diagnose --format a2a --auto-heal"
      },
      {
        "id": "afd-read-gate",
        "matcher": "Read",
        "command": "bash .claude/read-gate.sh"
      }
    ]
  }
}